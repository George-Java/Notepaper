{
  "name": "floral-notepaper",
  "version": "1.0.4",
  "private": true,
  "description": "轻量、优雅、现代化的本地便签工具（Electron + React）",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"vite\" \"wait-on http://localhost:1420 && cross-env ELECTRON_DEV=true electron dist-electron/main.js\"",
    "build:renderer": "tsc && vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build:dist": "npm run build:renderer && npm run build:electron",
    "build:win": "npm run build:dist && electron-builder --win",
    "build:mac": "npm run build:dist && electron-builder --mac",
    "build:linux": "npm run build:dist && electron-builder --linux",
    "build": "npm run build:dist && electron-builder",
    "test": "vitest run",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "preview": "vite preview",
    "prepare": "husky",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@tanstack/react-hotkeys": "^0.10.0",
    "chroma-js": "^3.2.0",
    "highlight.js": "^11.11.1",
    "i18next": "^26.2.0",
    "indent-textarea": "^4.0.0",
    "katex": "^0.16.47",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/chroma-js": "^3.1.2",
    "@types/katex": "^0.16.8",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "tailwindcss": "^4.2.4",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.0.0",
    "wait-on": "^8.0.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,css,json,yml,yaml,html,md}": "oxfmt"
  }
}
